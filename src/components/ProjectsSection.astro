---
const projects = ["Proj_1", "Proj_2", "Proj_3", "Proj_4", "Proj_5", "Proj_6"];
---


<section class="projects">
	<!-- <h2>Projects</h2> -->


	<div class="projects-list">
		{projects.map(project =>
		(
			<div class="project">
				<a href={`/projects/${project}`}> {project} </a>
				<div class="project-description">
					<img src={`src/assets/Reference images/${project}.jpeg`} />
					<div>
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec a diam lectus. Sed sit amet ipsum mauris. Maecenas congue ligula ac quam viverra nec consectetur ante hendrerit. Donec et mollis dolor.
						<br>
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec a diam lectus. Sed sit amet ipsum mauris. Maecenas congue ligula ac quam viverra nec consectetur ante hendrerit. Donec et mollis dolor.
					</div>
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.projects
	{
		background: var(--bg);

		height: max-content;
		width: 100vw;
	}

	.projects .projects-list
	{
		display: grid;
		grid-template-columns: minmax(0px, min-content) minmax(min-content, 1fr);
	}

	.projects .projects-list .project
	{
		height: max-content;

		display: contents;
		
		text-align: center;
	}

	.projects .projects-list .project a
	{
		color: var(--txt);

		text-decoration: none;
		text-align: left;
	}

	.projects .projects-list .project .project-description
	{
		display: flex;
		flex-direction: row;

		opacity: 0;
  		transform: translateX(50px);

  		transition: opacity 0.4s cubic-bezier(.98,0,.06,.96), transform 0.4s cubic-bezier(.98,0,.06,.96);
	}

	.projects .projects-list .project .project-description img
	{
		width: 15vw;
		height: auto;
	}

	.projects .projects-list .project:hover .project-description
	{
		opacity: 1;
  		transform: translateX(0);
	}
</style>